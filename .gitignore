# AD PDFs (potentially sensitive/copyrighted)
ADs/*.pdf

# Excel data files (contain fleet-specific data)
*.xlsx
*.ods

# But include sample/demo Excel files
!Fleet_Database_SkyTech.xlsx
!SAMPLE_OUTPUT_Report.xlsx

# Reports with operational data
EASA_Reports/*.json
EASA_Reports/*.html
FAA_Reports/*.json
Audit_Evidence/*.json

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Keep directory structure
!.gitkeep
